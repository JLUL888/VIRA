# Copy to ".env" and adjust for your environment.

# Database — SQLite by default for zero-config local/dev use.
# For production, point this at a hosted Postgres/MySQL and update
# prisma/schema.prisma `datasource.provider` to match.
DATABASE_URL="file:./dev.db"

# Internal advisor dashboard access. The /dashboard area is gated by a
# single shared passphrase set here. Change before deploying. Leave blank
# in local development to disable the gate.
ADVISOR_DASHBOARD_PASSWORD="capecod"

# Public site URL (used for absolute links / metadata).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
